generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  currency    String  @default("EUR")
  imageUrl    String?
  active      Boolean @default(true)

  stockS Int @default(10)
  stockM Int @default(10)
  stockL Int @default(10)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]
}

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeSessionId   String? @unique
  stripePaymentId   String? @unique
  lastStripeEventId String? @unique

  email String?
  name  String?
  phone String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  country      String?

  currency String @default("EUR")

  paymentStatus     String @default("pending")
  fulfillmentStatus String @default("unfulfilled")

  shippingCarrier String?
  trackingNumber  String?
  trackingUrl     String?

  shippedAt           DateTime?
  shippingEmailSentAt DateTime?

  deliveredAt          DateTime?
  deliveredEmailSentAt DateTime?

  shippingCents Int @default(0)
  subtotalCents Int @default(0)
  totalCents    Int @default(0)

  nazPrivateAccess            Boolean   @default(false)
  nazPrivateAccessGrantedAt   DateTime?
  nazPrivateAccessEmailSentAt DateTime?

  confirmationEmailSentAt DateTime?
  adminEmailSentAt        DateTime?

  items OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  name       String
  priceCents Int
  quantity   Int
  size       String?
  createdAt  DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}
